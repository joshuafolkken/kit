		"globals": "^17.6.0",
		"js-yaml": "^4.2.0",
		"ora": "^9.4.0",
		"semver": "^7.8.4",
		"strip-json-comments": "^5.0.3",
		"tsx": "^4.22.4",
		"typescript-eslint": "^8.61.0",
		"zod": "^4.4.3"
	},
