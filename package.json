		"prepack": "tsx scripts/build-bin.ts",
		"josh": "tsx scripts/josh/josh.ts"
	},
	"files": [
		"dist",
		"scripts",
		"scripts-ai",
		"prompts",
		"templates",
		"eslint",
		"prettier",
		"tsconfig",
		"cspell",
		"lefthook",
		".claude",
		".vscode",
