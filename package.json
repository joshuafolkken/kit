{
	"version": "0.275.0",
	"name": "@joshuafolkken/kit",
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"engines": {
		"node": ">=22.19.0"
	},
	"bin": {
		"josh": "dist/josh.js"
	},
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain@1.5.1 setup-ci",
		"prepare": "lefthook install",
		"build": "tsx scripts/build-bin.ts && tsx scripts/build-version.ts",
		"prepack": "tsx scripts/build-bin.ts && tsx scripts/build-version.ts",
		"josh": "tsx scripts/josh/josh.ts"
	},
	"files": [
		"dist",
		"scripts",
		"scripts-ai",
		"prompts",
		"templates",
		"eslint",
		"prettier",
		"tsconfig",
		"cspell",
		"lefthook",
		".claude",
		".vscode",
		".github",
		"CLAUDE.md",
		"AGENTS.md",
		"GEMINI.md",
		"CODE_OF_CONDUCT.md",
		"SECURITY.md",
		".cursorrules",
		".coderabbit.yaml",
		".gitattributes",
		".mcp.json",
		".ncurc.json",
		".prettierignore",
		"pnpm-workspace.yaml",
		"tsconfig.sonar.json",
		"wrangler.jsonc",
		"playwright.config.ts",
		"!**/*.test.ts",
		"!**/*.spec.ts"
	],
	"imports": {
		"#scripts/*": "./scripts/*.ts"
	},
	"exports": {
		"./eslint/base": "./eslint/base.js",
		"./eslint/vanilla": "./eslint/vanilla.js",
		"./eslint/sveltekit": "./eslint/sveltekit.js",
		"./prettier": {
			"types": "./prettier/index.d.ts",
			"default": "./prettier/index.js"
		},
		"./tsconfig/base": {
			"types": "./tsconfig/base.jsonc",
			"default": "./tsconfig/base.jsonc"
		},
		"./tsconfig/sveltekit": {
			"types": "./tsconfig/sveltekit.jsonc",
			"default": "./tsconfig/sveltekit.jsonc"
		},
		"./cspell": "./cspell/index.yaml",
		"./cspell/sveltekit": "./cspell/sveltekit.yaml",
		"./version": {
			"types": "./dist/version/index.d.ts",
			"default": "./dist/version/index.js"
		}
	},
	"peerDependencies": {
		"@playwright/test": ">=1.0.0",
		"svelte": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@playwright/test": {
			"optional": true
		},
		"svelte": {
			"optional": true
		}
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@types/node": "^26.0.0",
		"@types/semver": "^7.7.1",
		"cspell": "^10.0.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"lefthook": "^2.1.9",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup": "^4.62.2",
		"rollup-plugin-dts": "^6.4.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.17.0",
		"eslint-plugin-promise": "^7.3.0",
		"eslint-plugin-sonarjs": "^4.1.0",
		"eslint-plugin-svelte": "^3.19.0",
		"eslint-plugin-unicorn": "^68.0.0",
		"execa": "^9.6.1",
		"globals": "^17.7.0",
		"js-yaml": "^5.1.0",
		"ora": "^9.4.1",
		"semver": "^7.8.5",
		"strip-json-comments": "^5.0.3",
		"tsx": "^4.22.4",
		"typescript-eslint": "^8.62.0",
		"zod": "^4.4.3"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.9.0",
			"onFail": "error"
		}
	}
}
