{
	"version": "0.193.0",
	"name": "@joshuafolkken/kit",
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
	"engines": {
		"node": ">=22.19.0"
	},
	"bin": {
		"josh": "./scripts/josh.ts"
	},
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain@1.5.1 setup-ci",
		"postinstall": "lefthook install && tsx scripts/install-bin.ts",
		"josh": "tsx scripts/josh.ts"
	},
	"files": [
		"scripts",
		"scripts-ai",
		"prompts",
		"templates",
		"eslint",
		"prettier",
		"tsconfig",
		"cspell",
		"lefthook",
		".claude",
		".vscode",
		".github",
		"CLAUDE.md",
		"AGENTS.md",
		"GEMINI.md",
		"CODE_OF_CONDUCT.md",
		"SECURITY.md",
		".cursorrules",
		".coderabbit.yaml",
		".gitattributes",
		".mcp.json",
		".ncurc.json",
		".prettierignore",
		"pnpm-workspace.yaml",
		"tsconfig.sonar.json",
		"wrangler.jsonc",
		"playwright.config.ts",
		"!**/*.test.ts",
		"!**/*.spec.ts"
	],
	"exports": {
		"./eslint/base": "./eslint/base.js",
		"./eslint/vanilla": "./eslint/vanilla.js",
		"./eslint/sveltekit": "./eslint/sveltekit.js",
		"./prettier": {
			"types": "./prettier/index.d.ts",
			"default": "./prettier/index.js"
		},
		"./tsconfig/base": {
			"types": "./tsconfig/base.jsonc",
			"default": "./tsconfig/base.jsonc"
		},
		"./tsconfig/sveltekit": {
			"types": "./tsconfig/sveltekit.jsonc",
			"default": "./tsconfig/sveltekit.jsonc"
		},
		"./cspell": "./cspell/index.yaml",
		"./cspell/sveltekit": "./cspell/sveltekit.yaml"
	},
	"peerDependencies": {
		"@playwright/test": ">=1.0.0",
		"svelte": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@playwright/test": {
			"optional": true
		},
		"svelte": {
			"optional": true
		}
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.9.1",
		"cspell": "^10.0.0",
		"eslint": "^10.4.0",
		"lefthook": "^2.1.8",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-promise": "^7.3.0",
		"eslint-plugin-sonarjs": "^4.0.3",
		"eslint-plugin-svelte": "^3.18.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^17.6.0",
		"js-yaml": "^4.1.1",
		"strip-json-comments": "^5.0.3",
		"tsx": "^4.22.3",
		"typescript-eslint": "^8.60.0",
		"zod": "^4.4.3"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0-0",
			"onFail": "error"
		}
	}
}
